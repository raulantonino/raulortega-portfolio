---
import { skillGroups } from '../../data/skills';

const featuredSkills = new Set(['Python', 'Django', 'SQL', 'Git']);
---

<section id="stack" class="skills-section">
  <div class="container skills-grid">
    <div class="skills-heading">
      <p class="eyebrow">Base técnica</p>
      <h2>Stack principal</h2>
      <p>
        Mi perfil combina desarrollo web, bases de datos, herramientas de trabajo
        colaborativo y una base analítica vinculada a ingeniería y procesos.
      </p>
    </div>

    <div class="skills-list">
      {skillGroups.map((group) => (
        <article class="skill-group">
          <h3>{group.title}</h3>

          <ul>
            {group.skills.map((skill) => (
              <li class={featuredSkills.has(skill) ? 'skill-chip skill-chip--featured' : 'skill-chip'}>
                {skill}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-section {
    padding: 5rem 0;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(2rem, 5vw, 4rem);
  }

  .skills-heading h2 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.05rem);
    font-weight: 400;
    line-height: 1.07;
    letter-spacing: 0;
  }

  .skills-heading p:not(.eyebrow) {
    color: var(--color-muted);
    font-size: 1.04rem;
    line-height: 1.75;
  }

  .skills-list {
    display: grid;
    gap: 1.5rem;
  }

  .skill-group {
    display: block;
  }

  .skill-group h3 {
    margin: 0 0 0.5rem;
    color: var(--color-muted);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .skill-group ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .skill-chip {
    display: inline-flex;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-soft);
    color: var(--color-heading);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .skill-chip--featured {
    border-color: var(--color-border-blue);
  }

  @media (max-width: 900px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
