---
import { skillGroups } from '../../data/skills';
---

<section id="habilidades" class="skills-section">
  <div class="container skills-grid">
    <div class="skills-heading">
      <p class="eyebrow">Habilidades</p>
      <h2>Habilidades</h2>
      <p>
        Mi perfil combina desarrollo web, bases de datos, herramientas de trabajo
        colaborativo y una base analítica vinculada a ingeniería y procesos.
      </p>
    </div>

    <div class="skills-list">
      {skillGroups.map((group) => (
        <article class="skill-group">
          <h3>{group.title}</h3>

          <ul>
            {group.skills.map((skill) => <li>{skill}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-section {
    padding: 5rem 0;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(2rem, 5vw, 4rem);
  }

  .skills-heading h2 {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(2rem, 4vw, 3.05rem);
    line-height: 1.07;
    letter-spacing: 0;
  }

  .skills-heading p:not(.eyebrow) {
    color: var(--color-muted);
    font-size: 1.04rem;
    line-height: 1.75;
  }

  .skills-list {
    display: grid;
    gap: 0.75rem;
  }

  .skill-group {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1rem;
    padding: 1rem 0;
    border-top: 1px solid var(--color-border);
  }

  .skill-group:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .skill-group h3 {
    margin: 0;
    color: var(--color-heading);
    font-size: 1rem;
    letter-spacing: 0;
  }

  .skill-group ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .skill-group li {
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.76);
    color: var(--color-heading);
    font-size: 0.84rem;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .skills-grid,
    .skill-group {
      grid-template-columns: 1fr;
    }
  }
</style>
