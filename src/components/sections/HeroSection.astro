---
import { profile } from '../../data/profile';
---

<section id="inicio" class="hero">
  <div class="container hero-grid">
    <div class="portrait-column">
      <div class="portrait-frame">
        {
          profile.image ? (
            <img src={profile.image} alt={`Retrato de ${profile.formalName}`} />
          ) : (
            <div class="portrait-placeholder">
              <span>Foto</span>
              <strong>profesional</strong>
              <small>pendiente</small>
            </div>
          )
        }
      </div>
    </div>

    <div class="hero-copy">
      <p class="eyebrow">Portfolio profesional</p>

      <h1>{profile.formalName}</h1>

      <p class="hero-role">{profile.role}</p>

      <div class="contact-line">
        <a href={profile.links.email}>{profile.email}</a>
        <span>{profile.location}</span>
      </div>

      <div class="button-row">
        <a class="button button--primary" href="/#proyectos">Ver proyectos</a>
        <a class="button button--secondary" href={profile.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        <a class="button button--secondary" href={profile.links.github} target="_blank" rel="noreferrer">GitHub</a>
      </div>

      <p class="hero-headline">{profile.headline}</p>

      <p class="hero-summary">{profile.summary}</p>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 6rem 0 5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(220px, 320px) minmax(0, 1fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }

  .portrait-column {
    display: flex;
    justify-content: center;
  }

  .portrait-frame {
    display: grid;
    width: min(100%, 290px);
    aspect-ratio: 1;
    overflow: hidden;
    place-items: center;
    border: 1px solid rgba(15, 23, 42, 0.09);
    border-radius: 50%;
    background: var(--color-surface);
    box-shadow: 0 22px 55px rgba(15, 23, 42, 0.08);
  }

  .portrait-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .portrait-placeholder {
    display: grid;
    text-align: center;
    color: var(--color-muted);
  }

  .portrait-placeholder span {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .portrait-placeholder strong {
    color: var(--color-heading);
    font-size: 1.45rem;
    letter-spacing: -0.055em;
  }

  .portrait-placeholder small {
    font-size: 0.85rem;
  }

  .hero-copy {
    max-width: 820px;
  }

  .hero-copy h1 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: clamp(3rem, 6.5vw, 5.1rem);
    line-height: 0.98;
    letter-spacing: -0.075em;
  }

  .hero-role {
    margin: 0.65rem 0 0;
    color: var(--color-muted);
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    line-height: 1.25;
    letter-spacing: -0.045em;
  }

  .contact-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.2rem;
    margin-top: 1.25rem;
    color: var(--color-muted);
    font-weight: 680;
  }

  .contact-line a:hover {
    color: var(--color-primary);
  }

  .button-row {
    margin-top: 1.25rem;
  }

  .hero-headline {
    margin: 2rem 0 0;
    max-width: 760px;
    color: var(--color-heading);
    font-size: clamp(1.28rem, 2vw, 1.65rem);
    font-weight: 760;
    line-height: 1.28;
    letter-spacing: -0.045em;
  }

  .hero-summary {
    margin: 0.85rem 0 0;
    max-width: 760px;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  @media (max-width: 840px) {
    .hero {
      padding: 4rem 0 3.5rem;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .portrait-column {
      justify-content: flex-start;
    }

    .portrait-frame {
      width: 220px;
    }
  }
</style>
