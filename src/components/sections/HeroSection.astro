---
import { profile } from '../../data/profile';
---

<section id="inicio" class="hero">
  <div class="container hero-inner">
    <div class="hero-copy">
      <h1>{profile.displayName}</h1>
      <div aria-hidden="true" style="width: 48px; height: 2.5px; background: var(--color-accent); border-radius: 2px; margin: 0.75rem 0 1.25rem;"></div>

      <p class="hero-role">{profile.role}</p>

      <p class="hero-headline">{profile.headline}</p>

      <div class="button-row hero-actions">
        <a class="button button--primary" href={profile.links.cv} target="_blank" rel="noopener noreferrer" aria-label={`Descargar CV de ${profile.displayName} en PDF`}>Descargar CV</a>
        <a class="button button--secondary" href={profile.links.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`Abrir LinkedIn de ${profile.displayName}`}>LinkedIn</a>
        <a class="button button--secondary" href={profile.links.github} target="_blank" rel="noopener noreferrer" aria-label={`Abrir GitHub de ${profile.displayName}`}>GitHub</a>
      </div>
    </div>

    <div class="hero-portrait">
      <picture>
        <source srcset={profile.imageWebp} type="image/webp" />
        <img
          src={profile.image}
          alt={`Retrato de ${profile.formalName}`}
          width="640"
          height="853"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 3rem 0 clamp(4rem, 8vw, 6rem);
    background: var(--color-bg);
  }

  .hero-inner {
    display: flex;
    flex-direction: row;
    gap: 4rem;
    align-items: flex-start;
  }

  .hero-copy {
    flex: 1;
    max-width: 680px;
  }

  .hero-copy h1 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 4.5vw, 3.8rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .hero-role {
    margin: 0.9rem 0 0;
    color: var(--color-muted);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0;
  }

  .hero-headline {
    margin: 2rem 0 0;
    max-width: 660px;
    color: var(--color-text);
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0;
  }

  .hero-actions {
    margin-top: 1.55rem;
  }

  .hero-portrait {
    align-self: flex-start;
    flex-shrink: 0;
    width: 260px;
  }

  .hero-portrait picture,
  .hero-portrait img {
    display: block;
  }

  .hero-portrait img {
    width: 100%;
    aspect-ratio: 3 / 4;
    height: auto;
    border-radius: 0.75rem;
    object-fit: cover;
    object-position: center top;
    box-shadow:
      0 1px 3px rgba(15, 23, 42, 0.06),
      0 8px 24px rgba(15, 23, 42, 0.08);
  }

  @media (max-width: 720px) {
    .hero {
      padding: 3rem 0 3.25rem;
    }

    .hero-inner {
      flex-direction: column;
      gap: 1.5rem;
      align-items: flex-start;
    }

    .hero-portrait {
      order: -1;
      width: min(100%, 140px);
      max-width: 140px;
      margin: 0 auto;
    }

    .hero-portrait img {
      aspect-ratio: 1 / 1;
      object-position: center 20%;
    }
  }
</style>
