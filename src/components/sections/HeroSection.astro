---
import { profile } from '../../data/profile';
---

<section id="inicio" class="hero">
  <div class="container">
    <div class="hero-copy">
      <h1>{profile.displayName}</h1>

      <p class="hero-role">{profile.role}</p>

      <p class="hero-headline">{profile.headline}</p>

      <p class="hero-summary">{profile.summary}</p>

      <div class="button-row hero-actions">
        <a class="button button--primary" href="/#proyectos">Ver proyectos</a>
        <a class="button button--secondary" href={profile.links.cv} target="_blank" rel="noopener noreferrer">Descargar CV</a>
        <a class="button button--secondary" href={profile.links.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>

      <div class="hero-links" aria-label="Enlaces rápidos">
        <a class="text-link" href={profile.links.github} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a class="text-link" href={profile.links.email}>{profile.email}</a>
        <span>{profile.location}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: clamp(5rem, 10vw, 8rem) 0 clamp(4rem, 8vw, 6rem);
    background: var(--color-bg);
  }

  .hero-copy {
    max-width: 680px;
  }

  .hero-copy h1 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 6vw, 5rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
  }

  .hero-role {
    margin: 0.9rem 0 0;
    color: var(--color-primary-deep);
    font-size: clamp(1.12rem, 2vw, 1.45rem);
    font-weight: 760;
    line-height: 1.3;
    letter-spacing: 0;
  }

  .hero-headline {
    margin: 2rem 0 0;
    max-width: 660px;
    color: var(--color-heading);
    font-size: clamp(1.45rem, 2.2vw, 1.9rem);
    font-weight: 680;
    line-height: 1.26;
    letter-spacing: 0;
  }

  .hero-summary {
    margin: 1rem 0 0;
    max-width: 640px;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .hero-actions {
    margin-top: 1.55rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    align-items: center;
    margin-top: 1rem;
    color: var(--color-muted);
    font-size: 0.95rem;
    font-weight: 680;
  }

  .hero-links span {
    color: var(--color-muted);
  }

  @media (max-width: 720px) {
    .hero {
      padding: 4rem 0 3.25rem;
    }

    .hero-links {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
