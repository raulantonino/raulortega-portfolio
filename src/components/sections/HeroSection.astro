---
import { profile } from '../../data/profile';
---

<section id="inicio" class="hero">
  <div class="container hero-inner">
    <div class="hero-copy">
      <h1>{profile.displayName}</h1>

      <p class="hero-role">{profile.role}</p>

      <p class="hero-headline">{profile.headline}</p>

      <p class="hero-summary">{profile.summary}</p>

      <div class="button-row hero-actions">
        <a class="button button--primary" href="/#proyectos">Ver proyectos</a>
        <a class="button button--secondary" href={profile.links.cv} target="_blank" rel="noopener noreferrer">Descargar CV</a>
        <a class="button button--secondary" href={profile.links.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>

      <p class="hero-location">{profile.location}</p>
    </div>

    <div class="hero-portrait">
      <picture>
        <source srcset={profile.imageWebp} type="image/webp" />
        <img
          src={profile.image}
          alt={`Retrato de ${profile.formalName}`}
          width="640"
          height="853"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: clamp(5rem, 10vw, 8rem) 0 clamp(4rem, 8vw, 6rem);
    background: var(--color-bg);
  }

  .hero-inner {
    display: flex;
    gap: 4rem;
    align-items: center;
  }

  .hero-copy {
    flex: 1;
    max-width: 680px;
  }

  .hero-copy h1 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 4.5vw, 3.8rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .hero-role {
    margin: 0.9rem 0 0;
    color: var(--color-muted);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0;
  }

  .hero-headline {
    margin: 2rem 0 0;
    max-width: 660px;
    color: var(--color-text);
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0;
  }

  .hero-summary {
    margin: 1rem 0 0;
    max-width: 640px;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .hero-actions {
    margin-top: 1.55rem;
  }

  .hero-location {
    margin: 0.85rem 0 0;
    color: var(--color-muted);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .hero-portrait {
    flex-shrink: 0;
    width: 280px;
  }

  .hero-portrait picture,
  .hero-portrait img {
    display: block;
  }

  .hero-portrait img {
    width: 100%;
    aspect-ratio: 3 / 4;
    height: auto;
    border-radius: 0.75rem;
    object-fit: cover;
    box-shadow:
      0 1px 3px rgba(15, 23, 42, 0.06),
      0 8px 24px rgba(15, 23, 42, 0.08);
  }

  @media (max-width: 720px) {
    .hero {
      padding: 4rem 0 3.25rem;
    }

    .hero-inner {
      flex-direction: column;
      gap: 1.5rem;
      align-items: flex-start;
    }

    .hero-portrait {
      order: -1;
      width: min(100%, 140px);
    }

    .hero-portrait img {
      aspect-ratio: 1 / 1;
    }
  }
</style>
