---
import { featuredProjects } from '../../data/projects';

const projects = featuredProjects.slice(0, 3);
---

<section id="proyectos" class="projects-section">
  <div class="container section-header">
    <h2 class="section-title">Proyectos</h2>
    <p class="section-description">
      Aplicaciones web desarrolladas con foco en backend, datos, lógica de negocio
      y decisiones técnicas explicables.
    </p>
  </div>

  <div class="container projects-list">
    {projects.map((project) => (
      <article class="project-feature">
        <a class="project-media" href={`/proyectos/${project.slug}`} aria-label={`Ver caso de estudio de ${project.name}`}>
          <picture>
            <source srcset={project.images.previewWebp} type="image/webp" />
            <img
              src={project.images.preview}
              alt={`Captura de ${project.name}`}
              width="1200"
              height="675"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </a>

        <div class="project-content">
          <p class="project-type">{project.type}</p>
          <h3>{project.name}</h3>
          <p class="summary">{project.summary}</p>

          <ul class="tech-list">
            {project.technologies.slice(0, 4).map((tech) => <li>{tech}</li>)}
          </ul>

          <div class="project-links">
            {project.demoUrl && <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" aria-label={`Ver demo de ${project.name}`}>Ver demo</a>}
            <a href={`/proyectos/${project.slug}`} aria-label={`Ver caso de estudio de ${project.name}`}>Ver caso</a>
            <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" aria-label={`Ver repositorio GitHub de ${project.name}`}>GitHub</a>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="container section-action">
    <a class="text-link" href="/proyectos">Explorar todos los proyectos</a>
  </div>
</section>

<style>
  .projects-section {
    padding: 5rem 0;
    background: #eef3f7;
    border-top: 1px solid var(--color-border);
  }

  .section-header {
    margin-bottom: 2rem;
    text-align: left;
  }

  .projects-list {
    display: grid;
    gap: 1.25rem;
  }

  .project-feature {
    display: grid;
    grid-template-columns: minmax(220px, 0.42fr) minmax(0, 1fr);
    gap: clamp(1.1rem, 3vw, 1.6rem);
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    box-shadow: var(--shadow-soft);
  }

  .project-media {
    display: block;
    min-height: 100%;
    background: var(--color-bg-soft);
  }

  .project-media picture,
  .project-media img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .project-media img {
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .project-content {
    padding: clamp(1rem, 3vw, 1.35rem) clamp(1rem, 3vw, 1.5rem) clamp(1rem, 3vw, 1.35rem) 0;
  }

  .project-type {
    margin: 0 0 0.65rem;
    color: var(--color-primary-deep);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-content h3 {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(1.4rem, 2.6vw, 2rem);
    line-height: 1.12;
    letter-spacing: 0;
  }

  .summary {
    color: var(--color-muted);
    line-height: 1.68;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tech-list li {
    padding: 0.36rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-heading);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.1rem;
    font-weight: 700;
  }

  .project-links a {
    color: var(--color-heading);
    border-bottom: 1px solid rgba(47, 111, 237, 0.28);
  }

  .project-links a:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .section-action {
    margin-top: 1.5rem;
  }

  @media (max-width: 960px) {
    .project-feature {
      grid-template-columns: 1fr;
    }

    .project-content {
      padding: 0 1rem 1.1rem;
    }
  }
</style>
