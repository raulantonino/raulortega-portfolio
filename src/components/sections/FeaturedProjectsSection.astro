---
import { featuredProjects } from '../../data/projects';

const projects = featuredProjects.slice(0, 3);
---

<section id="proyectos" class="projects-section">
  <div class="container section-header">
    <p class="eyebrow">Proyectos destacados</p>
    <h2>Proyectos Django con evidencia técnica concreta.</h2>
    <p>
      Una selección breve de proyectos desarrollados de inicio a fin, con foco en
      backend, datos, reglas de negocio y código revisable.
    </p>
  </div>

  <div class="container projects-list">
    {projects.map((project, index) => (
      <article class="project-feature">
        <div class="project-index">0{index + 1}</div>

        <div class="project-content">
          <p class="project-type">{project.type}</p>
          <h3>{project.name}</h3>
          <p class="summary">{project.summary}</p>

          <div class="project-evidence">
            <ul>
              {project.caseStudy.technicalHighlights.slice(0, 2).map((highlight) => <li>{highlight}</li>)}
            </ul>
          </div>

          <ul class="tech-list">
            {project.technologies.slice(0, 5).map((tech) => <li>{tech}</li>)}
          </ul>

          <div class="project-links">
            {project.demoUrl && <a href={project.demoUrl} target="_blank" rel="noopener noreferrer">Ver demo</a>}
            <a href={`/proyectos/${project.slug}`}>Ver caso</a>
            <a href={project.repoUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="container section-action">
    <a class="text-link" href="/proyectos">Explorar todos los proyectos</a>
  </div>
</section>

<style>
  .projects-section {
    padding: 5rem 0;
    background: #eef3f7;
    border-top: 1px solid var(--color-border);
  }

  .section-header {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: end;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(2rem, 4vw, 3.15rem);
    line-height: 1.06;
    letter-spacing: 0;
  }

  .section-header p:not(.eyebrow) {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.04rem;
    line-height: 1.75;
  }

  .projects-list {
    display: grid;
    gap: 1rem;
  }

  .project-feature {
    display: grid;
    grid-template-columns: 3rem minmax(0, 1fr);
    gap: 1.2rem;
    padding: clamp(1rem, 3vw, 1.35rem);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.045);
  }

  .project-index {
    color: rgba(15, 23, 42, 0.32);
    font-size: 0.9rem;
    font-weight: 850;
  }

  .project-content {
    padding: 0.1rem 0;
  }

  .project-type {
    margin: 0 0 0.65rem;
    color: var(--color-primary-deep);
    font-size: 0.76rem;
    font-weight: 820;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .project-content h3 {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .summary,
  .project-evidence li {
    color: var(--color-muted);
    line-height: 1.68;
  }

  .project-evidence ul {
    display: grid;
    gap: 0.35rem;
    margin: 0.9rem 0 0;
    padding-left: 1.1rem;
  }

  .project-evidence li {
    padding-left: 0.1rem;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tech-list li {
    padding: 0.36rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-heading);
    font-size: 0.8rem;
    font-weight: 720;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.1rem;
    font-weight: 780;
  }

  .project-links a {
    color: var(--color-heading);
    border-bottom: 1px solid rgba(47, 111, 237, 0.28);
  }

  .project-links a:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .section-action {
    margin-top: 1.5rem;
  }

  @media (max-width: 960px) {
    .section-header,
    .project-feature {
      grid-template-columns: 1fr;
    }

    .project-index {
      margin-bottom: -0.4rem;
    }
  }
</style>
