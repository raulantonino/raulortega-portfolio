---
import { education } from '../../data/experience';
---

<section id="formacion" class="cv-section">
  <div class="container">
    <div class="section-heading">
      <h2>Formación</h2>
      <p>
        Base académica y técnica que respalda mi transición al desarrollo web.
      </p>
    </div>

    <div class="education-grid">
      {education.map((item) => (
        <article class="education-card">
          <p>{item.period}</p>
          <h3>{item.title}</h3>
          <span>{item.institution}</span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cv-section {
    padding: 5rem 0;
    background: #ffffff;
    border-top: 1px solid var(--color-border);
  }

  .section-heading {
    margin-bottom: 1.75rem;
  }

  .section-heading h2 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
  }

  .section-heading p {
    max-width: 680px;
    margin: 0.9rem 0 0;
    color: var(--color-muted);
    font-size: 1.04rem;
    line-height: 1.72;
  }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .education-card {
    padding: 1.1rem 0;
    border-top: 1px solid var(--color-border);
  }

  .education-card p {
    margin: 0 0 0.6rem;
    color: var(--color-primary-deep);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .education-card h3 {
    margin: 0;
    color: var(--color-heading);
    font-size: 1.22rem;
    line-height: 1.22;
    letter-spacing: 0;
  }

  .education-card span {
    display: block;
    margin-top: 0.55rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  @media (max-width: 860px) {
    .education-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
