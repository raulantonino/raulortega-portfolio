---
import { featuredExperience } from '../../data/experience';
---

<section class="home-section">
  <div class="container section-header">
    <p class="eyebrow">Experiencia destacada</p>
    <h2>Experiencia técnica, datos y procesos.</h2>
    <p>
      Selección de experiencias que conectan desarrollo web, análisis de información,
      trabajo con sistemas y coordinación profesional.
    </p>
  </div>

  <div class="container experience-grid">
    {featuredExperience.map((experience) => (
      <article class="experience-card">
        <p class="period">{experience.period}</p>
        <h3>{experience.role}</h3>
        <p class="organization">{experience.organization}</p>
        <p class="summary">{experience.summary}</p>

        <ul class="highlight-list">
          {experience.highlights.slice(0, 2).map((highlight) => <li>{highlight}</li>)}
        </ul>

        <div class="tag-list">
          {experience.tags.slice(0, 4).map((tag) => <span>{tag}</span>)}
        </div>
      </article>
    ))}
  </div>

  <div class="container section-action">
    <a class="text-link" href="/sobre-mi">Ver recorrido completo</a>
  </div>
</section>

<style>
  .home-section {
    padding: 5rem 0;
  }

  .section-header {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: end;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(2rem, 4vw, 3.15rem);
    line-height: 1.06;
    letter-spacing: -0.058em;
  }

  .section-header p:not(.eyebrow) {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.04rem;
    line-height: 1.75;
  }

  .experience-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .experience-card {
    display: flex;
    min-height: 420px;
    flex-direction: column;
    padding: 1.35rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.04);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .experience-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-blue);
    box-shadow: 0 18px 44px rgba(15, 23, 42, 0.06);
  }

  .period {
    margin: 0 0 0.6rem;
    color: var(--color-primary-deep);
    font-size: 0.76rem;
    font-weight: 820;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .experience-card h3 {
    margin: 0;
    color: var(--color-heading);
    font-size: 1.26rem;
    line-height: 1.18;
    letter-spacing: -0.04em;
  }

  .organization {
    margin: 0.3rem 0 0;
    color: var(--color-muted);
    font-weight: 700;
  }

  .summary {
    margin: 1rem 0 0;
    color: var(--color-muted);
    line-height: 1.68;
  }

  .highlight-list {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
    color: var(--color-muted);
    line-height: 1.65;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 1.2rem;
  }

  .tag-list span {
    padding: 0.35rem 0.48rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-heading);
    font-size: 0.78rem;
    font-weight: 720;
  }

  .section-action {
    margin-top: 1.5rem;
  }

  @media (max-width: 940px) {
    .section-header,
    .experience-grid {
      grid-template-columns: 1fr;
    }

    .experience-card {
      min-height: auto;
    }
  }
</style>
