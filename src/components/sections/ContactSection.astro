---
import { profile } from '../../data/profile';
---

<section id="contacto" class="contact-section">
  <div class="container contact-card">
    <div>
      <p class="eyebrow">Contacto</p>
      <h2>Hablemos sobre roles trainee o junior en desarrollo web.</h2>
    </div>

    <div class="contact-content">
      <p>
        Busco sumarme a equipos donde pueda aportar construyendo aplicaciones web,
        ordenando lógica backend y entendiendo procesos o datos del negocio. Puedes
        escribirme por correo, revisar mi GitHub o conectar conmigo en LinkedIn.
      </p>
      <p class="contact-fit">{profile.availability}</p>

      <div class="button-row">
        <a class="button button--primary" href={profile.links.email} aria-label={`Enviar correo a ${profile.displayName}`}>Enviar correo</a>
        <a class="button button--secondary" href={profile.links.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`Abrir LinkedIn de ${profile.displayName}`}>LinkedIn</a>
        <a class="button button--secondary" href={profile.links.github} target="_blank" rel="noopener noreferrer" aria-label={`Abrir GitHub de ${profile.displayName}`}>GitHub</a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 5rem 0;
  }

  .contact-card {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 5vw, 4rem);
    padding: clamp(1.4rem, 4vw, 2.4rem);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(135deg, rgba(47, 111, 237, 0.07), rgba(138, 169, 154, 0.07)),
      var(--color-surface);
    box-shadow: 0 18px 44px rgba(15, 23, 42, 0.05);
  }

  .contact-card h2 {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(2rem, 4vw, 3.15rem);
    line-height: 1.06;
    letter-spacing: 0;
  }

  .contact-content p {
    margin: 0 0 1.4rem;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .contact-fit {
    display: inline-block;
    max-width: 100%;
    margin-bottom: 1.4rem !important;
    padding: 0.35rem 0.55rem;
    border: 1px solid var(--color-border-blue);
    border-radius: var(--radius-sm);
    color: var(--color-primary-deep) !important;
    background: var(--color-primary-soft);
    font-size: 0.86rem !important;
    font-weight: 760;
    line-height: 1.45 !important;
  }

  @media (max-width: 860px) {
    .contact-card {
      grid-template-columns: 1fr;
    }
  }
</style>
