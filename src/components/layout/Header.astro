---
import { profile } from '../../data/profile';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Ir al inicio">
      <span class="brand-name">{profile.displayName}</span>
      <span class="brand-line" aria-hidden="true"></span>
      <span class="brand-subtitle">Python · Django · SQL</span>
    </a>

    <nav class="main-nav" aria-label="Navegación principal">
      <a href="/sobre-mi">Sobre mí</a>
      <a href="/proyectos">Proyectos</a>
      <a href={profile.links.email}>Contacto</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 0.75rem 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 3.25rem;
    padding: 0.58rem 0.75rem;
    border: 1px solid rgba(15, 23, 42, 0.085);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 12px 36px rgba(15, 23, 42, 0.045);
    backdrop-filter: blur(10px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
  }

  .brand-name {
    color: var(--color-heading);
    font-size: 0.98rem;
    font-weight: 830;
    letter-spacing: -0.035em;
    white-space: nowrap;
  }

  .brand-line {
    width: 1px;
    height: 1rem;
    background: var(--color-border);
  }

  .brand-subtitle {
    color: var(--color-muted);
    font-size: 0.78rem;
    font-weight: 640;
    white-space: nowrap;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.1rem;
  }

  .main-nav a {
    padding: 0.48rem 0.62rem;
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    font-size: 0.9rem;
    font-weight: 700;
    transition:
      color 180ms ease,
      background 180ms ease;
  }

  .main-nav a:hover {
    color: var(--color-heading);
    background: rgba(47, 111, 237, 0.075);
  }

  @media (max-width: 760px) {
    .header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.65rem;
    }

    .brand {
      flex-wrap: wrap;
      row-gap: 0.2rem;
    }

    .main-nav {
      width: 100%;
      justify-content: space-between;
    }

    .main-nav a {
      padding-inline: 0.4rem;
      font-size: 0.86rem;
    }
  }

  @media (max-width: 420px) {
    .brand-line,
    .brand-subtitle {
      display: none;
    }
  }
</style>
