---
import { profile } from '../../data/profile';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Ir al inicio">
      <span class="brand-name">{profile.displayName}</span>
      <span class="brand-subtitle">Desarrollo web · Python · Django</span>
    </a>

    <nav class="main-nav" aria-label="Navegación principal">
      <a href="/sobre-mi">Sobre mí</a>
      <a href="/proyectos">Proyectos</a>
      <a href={profile.links.email}>Contacto</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 1rem 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(15, 23, 42, 0.09);
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.055);
    backdrop-filter: blur(14px);
  }

  .brand {
    display: inline-flex;
    flex-direction: column;
    gap: 0.12rem;
  }

  .brand-name {
    color: var(--color-heading);
    font-size: 1rem;
    font-weight: 850;
    letter-spacing: -0.035em;
  }

  .brand-subtitle {
    color: var(--color-muted);
    font-size: 0.76rem;
    font-weight: 650;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .main-nav a {
    padding: 0.55rem 0.72rem;
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    font-size: 0.92rem;
    font-weight: 720;
    transition:
      color 180ms ease,
      background 180ms ease;
  }

  .main-nav a:hover {
    color: var(--color-heading);
    background: var(--color-primary-soft);
  }

  @media (max-width: 760px) {
    .site-header {
      padding-top: 0.75rem;
    }

    .header-inner {
      align-items: flex-start;
      flex-direction: column;
      border-radius: var(--radius-lg);
    }

    .main-nav {
      width: 100%;
      justify-content: space-between;
      gap: 0.2rem;
    }

    .main-nav a {
      padding-inline: 0.45rem;
      font-size: 0.86rem;
    }
  }
</style>
