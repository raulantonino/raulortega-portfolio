---
import { profile } from '../../data/profile';

const currentPath = Astro.url.pathname;
const isProjectsPage = currentPath.startsWith('/proyectos');
const projectsHref = isProjectsPage ? '/proyectos' : '/#proyectos';
const projectsAriaCurrent = currentPath === '/proyectos/' ? 'page' : isProjectsPage ? 'location' : undefined;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/#inicio" aria-label="Ir al inicio">
      <span class="brand-name">{profile.displayName}</span>
      <span class="brand-subtitle">Python · Django · SQL</span>
    </a>

    <nav class="main-nav" aria-label="Navegación principal">
      <a href={projectsHref} aria-current={projectsAriaCurrent}>Proyectos</a>
      <a href="/#experiencia">Experiencia</a>
      <a class="desktop-only" href="/#stack">Stack</a>
      <a href="/#contacto">Contacto</a>
      <a href={profile.links.cv} target="_blank" rel="noopener noreferrer" aria-label={`Descargar CV de ${profile.displayName} en PDF`}>CV</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 0.75rem 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 3.25rem;
    padding: 0.58rem 0.75rem;
    border: 1px solid rgba(15, 23, 42, 0.085);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(10px);
  }

  .brand {
    display: inline-flex;
    flex-direction: column;
    gap: 0.08rem;
    min-width: max-content;
  }

  .brand-name {
    color: var(--color-heading);
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .brand-subtitle {
    color: var(--color-muted);
    font-size: 0.74rem;
    font-weight: 500;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.1rem;
  }

  .main-nav a {
    padding: 0.48rem 0.58rem;
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    font-size: 0.88rem;
    font-weight: 700;
    transition:
      color 180ms ease,
      background 180ms ease;
  }

  .main-nav a:hover {
    color: var(--color-heading);
    background: rgba(47, 111, 237, 0.075);
  }

  .main-nav a[aria-current] {
    color: var(--color-heading);
    background: rgba(47, 111, 237, 0.095);
  }

  @media (max-width: 860px) {
    .header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.65rem;
    }

    .main-nav {
      width: 100%;
      overflow-x: auto;
      padding-bottom: 0.15rem;
    }

    .main-nav a {
      white-space: nowrap;
    }

    .desktop-only {
      display: none;
    }
  }
</style>
