---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout title="Página no encontrada | Raúl Ortega">
  <div class="page-shell">
    <Header />

    <main class="not-found">
      <section class="container">
        <p class="eyebrow">Error 404</p>
        <h1>Página no encontrada.</h1>
        <p>
          La página que buscas no existe o fue movida. Puedes volver al inicio
          o revisar los proyectos disponibles.
        </p>

        <div class="button-row">
          <a class="button button--primary" href="/">Volver al inicio</a>
          <a class="button button--secondary" href="/proyectos">Ver proyectos</a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .not-found {
    display: grid;
    min-height: 70vh;
    place-items: center;
    padding: 4rem 0;
  }

  .not-found h1 {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 0.98;
    letter-spacing: -0.08em;
  }

  .not-found p:not(.eyebrow) {
    max-width: 620px;
    color: var(--color-muted);
    font-size: 1.08rem;
    line-height: 1.75;
  }
</style>
