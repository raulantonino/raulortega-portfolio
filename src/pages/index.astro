---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { profile } from '../data/profile';
---

<BaseLayout
  title={`${profile.displayName} | Portfolio profesional`}
  description={`${profile.formalName}, ${profile.role}. Portfolio profesional enfocado en desarrollo web con Python, Django y SQL.`}
>
  <div class="page-shell">
    <Header />

    <main>
      <section class="hero section">
        <div class="container hero-grid">
          <div class="hero-content">
            <p class="eyebrow">Portfolio profesional</p>

            <h1>{profile.displayName}</h1>

            <p class="hero-headline">{profile.headline}</p>

            <p class="hero-summary">{profile.summary}</p>

            <div class="button-row">
              <a class="button button--primary" href="/proyectos">Ver proyectos</a>
              <a class="button button--secondary" href="/sobre-mi">Conocer mi perfil</a>
              <a class="button button--secondary" href={profile.links.github} target="_blank" rel="noreferrer">
                GitHub
              </a>
            </div>
          </div>

          <aside class="profile-panel glass-card" aria-label="Resumen profesional">
            <div class="profile-panel-header">
              <p class="availability">Disponible para roles trainee/junior</p>
              <p class="location">{profile.location}</p>
            </div>

            <div class="profile-summary-box">
              <p class="box-label">Perfil</p>
              <h2>{profile.role}</h2>
              <p>
                Base en ingeniería, experiencia con datos y foco actual en desarrollo web.
                Busco integrarme a equipos donde pueda aportar orden, aprendizaje continuo
                y criterio técnico.
              </p>
            </div>

            <div class="tech-list" aria-label="Tecnologías principales">
              <span>Python</span>
              <span>Django</span>
              <span>SQL</span>
              <span>HTML</span>
              <span>CSS</span>
              <span>JavaScript</span>
              <span>Git</span>
              <span>GitHub</span>
            </div>
          </aside>
        </div>
      </section>

      <section class="section section--compact">
        <div class="container section-heading">
          <p class="eyebrow">Base del sitio</p>
          <h2 class="section-title">Un CV web pensado para mostrar experiencia, proyectos y criterio profesional.</h2>
          <p class="section-description">
            Esta primera versión organizará el perfil en secciones claras: experiencia destacada,
            proyectos técnicos, habilidades y contacto profesional.
          </p>
        </div>

        <div class="container preview-grid">
          <article class="preview-card glass-card">
            <p class="card-kicker">Experiencia</p>
            <h3>OTEC, MASISA y análisis de datos</h3>
            <p>
              Experiencia reciente en desarrollo Django y experiencia previa en datos,
              SAP, procesos y coordinación con distintas áreas.
            </p>
          </article>

          <article class="preview-card glass-card">
            <p class="card-kicker">Proyectos</p>
            <h3>Pokeparty como caso principal</h3>
            <p>
              Los proyectos se presentarán como mini casos de estudio, con problema,
              solución, tecnologías, decisiones y enlaces.
            </p>
          </article>

          <article class="preview-card glass-card">
            <p class="card-kicker">Contacto</p>
            <h3>Conexión profesional directa</h3>
            <p>
              El sitio priorizará contacto simple mediante email, LinkedIn y GitHub,
              sin agregar complejidad innecesaria al MVP.
            </p>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .hero {
    padding-top: 5.25rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(320px, 0.88fr);
    gap: 2.25rem;
    align-items: center;
  }

  .hero-content h1 {
    margin: 0;
    max-width: 760px;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 8vw, 6.1rem);
    line-height: 0.96;
    letter-spacing: -0.085em;
  }

  .hero-headline {
    margin: 1.35rem 0 0;
    max-width: 720px;
    color: var(--color-heading);
    font-size: clamp(1.45rem, 2.35vw, 2.1rem);
    font-weight: 760;
    line-height: 1.18;
    letter-spacing: -0.055em;
  }

  .hero-summary {
    margin: 1.05rem 0 1.75rem;
    max-width: 690px;
    color: var(--color-muted);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .profile-panel {
    position: relative;
    overflow: hidden;
    padding: 1.35rem;
  }

  .profile-panel::before {
    content: '';
    position: absolute;
    inset: 1rem 1rem auto auto;
    width: 5.4rem;
    height: 5.4rem;
    border-radius: 50%;
    background:
      linear-gradient(135deg, rgba(47, 111, 237, 0.15), rgba(138, 169, 154, 0.14));
    z-index: -1;
  }

  .profile-panel-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .availability,
  .location {
    margin: 0;
    font-size: 0.84rem;
    font-weight: 720;
  }

  .availability {
    color: var(--color-primary-deep);
  }

  .location {
    color: var(--color-muted);
  }

  .profile-summary-box {
    padding: 1.3rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface-soft);
  }

  .box-label,
  .card-kicker {
    margin: 0 0 0.65rem;
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .profile-summary-box h2 {
    margin: 0;
    color: var(--color-heading);
    font-size: 1.42rem;
    line-height: 1.18;
    letter-spacing: -0.045em;
  }

  .profile-summary-box p:not(.box-label) {
    margin: 0.85rem 0 0;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .tech-list span {
    padding: 0.46rem 0.62rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: #ffffff;
    color: var(--color-heading);
    font-size: 0.86rem;
    font-weight: 760;
  }

  .section-heading {
    margin-bottom: 1.35rem;
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .preview-card {
    padding: 1.45rem;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .preview-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-blue);
    box-shadow: 0 24px 64px rgba(15, 23, 42, 0.08);
  }

  .preview-card h3 {
    margin: 0;
    color: var(--color-heading);
    font-size: 1.25rem;
    line-height: 1.22;
    letter-spacing: -0.04em;
  }

  .preview-card p:not(.card-kicker) {
    margin: 0.85rem 0 0;
    color: var(--color-muted);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .hero {
      padding-top: 3.5rem;
    }

    .hero-grid,
    .preview-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .profile-panel-header {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
