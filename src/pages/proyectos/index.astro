---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { profile } from '../../data/profile';
import { allProjects } from '../../data/projects';

const siteUrl = (Astro.site ?? new URL(Astro.url.origin)).toString();
const projectsUrl = new URL('/proyectos/', siteUrl).toString();
const pageDescription = `Casos de estudio de ${profile.formalName}: proyectos Django, Python y SQL desarrollados de inicio a fin con contexto, evidencia técnica y código.`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Proyectos | ${profile.displayName}`,
  description: pageDescription,
  url: projectsUrl,
  inLanguage: 'es-CL',
  author: {
    '@type': 'Person',
    name: profile.formalName,
    url: new URL('/', siteUrl).toString(),
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: allProjects.map((project, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: new URL(`/proyectos/${project.slug}/`, siteUrl).toString(),
      name: project.name,
    })),
  },
};
---

<BaseLayout
  title={`Proyectos | ${profile.displayName}`}
  description={pageDescription}
  jsonLd={jsonLd}
>
  <div class="page-shell">
    <Header />

    <main id="contenido-principal" tabindex="-1">
      <section class="page-hero">
        <div class="container page-hero-grid">
          <div>
            <h1>Proyectos</h1>
          </div>

          <p>
            Una vista rápida para comparar proyectos, revisar el foco técnico y
            elegir qué caso leer con más detalle.
          </p>
        </div>
      </section>

      <section class="projects-section">
        <div class="container projects-list">
          {allProjects.map((project) => (
            <article class="project-entry">
              <a class="project-media" href={`/proyectos/${project.slug}`} aria-label={`Ver caso de estudio de ${project.name}`}>
                <picture>
                  <source srcset={project.images.previewWebp} type="image/webp" />
                  <img
                    src={project.images.preview}
                    alt={`Captura de ${project.name}`}
                    width="1200"
                    height="675"
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
              </a>

              <div class="project-body">
                <h2>{project.name}</h2>
                <p class="project-type">{project.type}</p>
                <p class="project-summary">{project.summary}</p>

                <div class="project-focus">
                  <strong>Foco del proyecto</strong>
                  <p>{project.problem}</p>
                </div>

                <ul class="tech-list" aria-label={`Tecnologías usadas en ${project.name}`}>
                  {project.technologies.slice(0, 4).map((tech) => <li>{tech}</li>)}
                </ul>

                <div class="project-links">
                  <a href={`/proyectos/${project.slug}`} aria-label={`Ver caso de estudio de ${project.name}`}>Ver caso</a>
                  {project.demoUrl && <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" aria-label={`Ver demo de ${project.name}`}>Ver demo</a>}
                  <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" aria-label={`Ver repositorio GitHub de ${project.name}`}>GitHub</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .page-hero {
    padding: 5rem 0 3.5rem;
  }

  .page-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: end;
  }

  .page-hero h1 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.2rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .page-hero p:not(.eyebrow) {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.12rem;
    line-height: 1.78;
  }

  .projects-section {
    padding: 1rem 0 5rem;
  }

  .projects-list {
    display: grid;
    gap: 1.5rem;
  }

  .project-entry {
    display: grid;
    grid-template-columns: minmax(240px, 0.42fr) minmax(0, 1fr);
    gap: clamp(1.25rem, 4vw, 2rem);
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    box-shadow: var(--shadow-soft);
  }

  .project-media {
    display: block;
    min-height: 100%;
    background: var(--color-bg-soft);
  }

  .project-media picture,
  .project-media img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .project-media img {
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .project-body {
    padding: clamp(1.1rem, 3vw, 1.6rem) clamp(1.1rem, 3vw, 1.7rem) clamp(1.1rem, 3vw, 1.6rem) 0;
  }

  .project-type {
    margin: 0.45rem 0 0;
    color: var(--color-muted);
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.5;
  }

  .project-body h2 {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(1.55rem, 3vw, 2.25rem);
    line-height: 1.12;
    letter-spacing: 0;
  }

  .project-summary,
  .project-focus p {
    color: var(--color-muted);
    line-height: 1.7;
  }

  .project-focus {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .project-focus strong {
    color: var(--color-heading);
    font-size: 0.9rem;
  }

  .project-focus p {
    margin: 0.45rem 0 0;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tech-list li {
    padding: 0.36rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-heading);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.1rem;
    font-weight: 700;
  }

  .project-links a {
    color: var(--color-heading);
    border-bottom: 1px solid rgba(47, 111, 237, 0.28);
  }

  .project-links a:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  @media (max-width: 860px) {
    .page-hero-grid,
    .project-entry {
      grid-template-columns: 1fr;
    }

    .project-body {
      padding: 0 1rem 1.15rem;
    }
  }

  @media (max-width: 560px) {
    .page-hero {
      padding: 3.5rem 0 2.4rem;
    }

    .page-hero h1 {
      font-size: clamp(2.6rem, 14vw, 3.2rem);
      line-height: 1;
    }

    .page-hero p:not(.eyebrow) {
      font-size: 1rem;
      line-height: 1.65;
    }

    .projects-section {
      padding: 0.25rem 0 3.5rem;
    }
  }

  @media (max-width: 380px) {
    .project-body {
      padding: 0 0.85rem 1rem;
    }

    .project-links {
      gap: 0.75rem;
    }
  }
</style>
