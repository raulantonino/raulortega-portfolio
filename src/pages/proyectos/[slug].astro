---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { allProjects } from '../../data/projects';
import { profile } from '../../data/profile';

export function getStaticPaths() {
  return allProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const siteUrl = (Astro.site ?? new URL(Astro.url.origin)).toString();
const homeUrl = new URL('/', siteUrl).toString();
const projectsUrl = new URL('/proyectos/', siteUrl).toString();
const projectUrl = new URL(`/proyectos/${project.slug}/`, siteUrl).toString();
const projectImageUrl = new URL(project.images.case, siteUrl).toString();
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareSourceCode',
    name: project.name,
    description: project.seoDescription,
    url: projectUrl,
    image: projectImageUrl,
    codeRepository: project.repoUrl,
    programmingLanguage: 'Python',
    runtimePlatform: 'Django',
    applicationCategory: 'WebApplication',
    author: {
      '@type': 'Person',
      name: profile.formalName,
      url: homeUrl,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Inicio',
        item: homeUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Proyectos',
        item: projectsUrl,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: project.name,
        item: projectUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={`${project.name} | Caso de estudio`}
  description={project.seoDescription}
  image={project.images.case}
  imageAlt={`Captura principal de ${project.name}`}
  type="article"
  jsonLd={jsonLd}
>
  <div class="page-shell">
    <Header />

    <main id="contenido-principal" tabindex="-1">
      <section class="case-hero">
        <div class="container case-hero-grid">
          <div>
            <p class="eyebrow">Caso de estudio</p>
            <h1>{project.name}</h1>
            <p class="project-type">{project.type}</p>
          </div>

          <div class="case-summary">
            <p>{project.summary}</p>
            <p class="case-objective"><strong>Objetivo:</strong> {project.caseStudy.objective}</p>

            <div class="case-links">
              {project.demoUrl && <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" aria-label={`Ver demo de ${project.name}`}>Ver demo</a>}
              <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" aria-label={`Ver repositorio GitHub de ${project.name}`}>Ver GitHub</a>
              <a href="/proyectos">Volver a proyectos</a>
            </div>

            {project.demoNote && <p class="demo-note">{project.demoNote}</p>}
          </div>
        </div>
      </section>

      <section class="case-media-section">
        <div class="container">
          <div class="case-media">
            <picture>
              <source srcset={project.images.caseWebp} type="image/webp" />
              <img
                src={project.images.case}
                alt={`Captura principal de ${project.name}`}
                width="1600"
                height="900"
                decoding="async"
                loading="lazy"
              />
            </picture>
          </div>
        </div>
      </section>

      <section class="case-overview-section">
        <div class="container case-facts">
          <div>
            <span>Rol</span>
            <p>{project.caseStudy.role}</p>
          </div>

          <div>
            <span>Tipo</span>
            <p>{project.caseStudy.challengeType}</p>
          </div>

          <div>
            <span>Stack</span>
            <ul class="inline-list">
              {project.technologies.slice(0, 5).map((tech) => <li>{tech}</li>)}
            </ul>
          </div>

          <div>
            <span>Alcance</span>
            <p>{project.caseStudy.scope.slice(0, 2).join(' ')}</p>
          </div>
        </div>
      </section>

      <section class="case-content-section">
        <div class="container case-layout">
          <aside class="case-aside" aria-label={`Resumen técnico de ${project.name}`}>
            <div class="aside-block">
              <h2>Datos clave</h2>
              <ul>
                {project.caseStudy.metrics.map((metric) => <li>{metric}</li>)}
              </ul>
            </div>

            <div class="aside-block">
              <h2>Requisitos base</h2>
              <ul>
                {project.caseStudy.requirements.map((requirement) => <li>{requirement}</li>)}
              </ul>
            </div>
          </aside>

          <article class="case-article">
            <section class="case-section">
              <h2>Contexto</h2>
              <p>{project.caseStudy.context}</p>
              <p>{project.caseStudy.ownership}</p>
            </section>

            <section class="case-section">
              <h2>Problema</h2>
              <p>{project.caseStudy.challenge}</p>
              <p>{project.caseStudy.technicalChallenge}</p>
            </section>

            <section class="case-section">
              <h2>Enfoque</h2>
              <p>{project.caseStudy.approach}</p>
            </section>

            <section class="case-section">
              <h2>Decisiones técnicas</h2>
              <ul>
                {project.caseStudy.decisions.map((decision) => <li>{decision}</li>)}
              </ul>
            </section>

            <section class="case-section">
              <h2>Resultado</h2>
              <p>{project.caseStudy.result}</p>
              <ul>
                {project.caseStudy.technicalHighlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
            </section>

            <section class="case-section case-section--split">
              <div>
                <h2>Aprendizajes</h2>
                <ul>
                  {project.caseStudy.learnings.map((learning) => <li>{learning}</li>)}
                </ul>
              </div>

              <div>
                <h2>Próximos pasos</h2>
                <ul>
                  {project.caseStudy.nextSteps.map((step) => <li>{step}</li>)}
                </ul>
              </div>
            </section>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .case-hero {
    padding: 5rem 0 3rem;
  }

  .case-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: end;
  }

  .case-hero h1 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.2rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .project-type {
    margin: 1rem 0 0;
    color: var(--color-primary-deep);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-summary p {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.12rem;
    line-height: 1.78;
  }

  .case-objective {
    margin-top: 1rem !important;
  }

  .case-objective strong {
    color: var(--color-heading);
  }

  .case-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.3rem;
    font-weight: 700;
  }

  .case-links a {
    color: var(--color-heading);
    border-bottom: 1px solid rgba(47, 111, 237, 0.28);
  }

  .case-links a:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .demo-note {
    margin-top: 0.9rem !important;
    padding-left: 0.75rem;
    border-left: 2px solid var(--color-border-blue);
    color: var(--color-primary-deep) !important;
    font-size: 0.92rem !important;
    line-height: 1.5 !important;
  }

  .case-media-section {
    padding: 1rem 0 2.5rem;
  }

  .case-media {
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    box-shadow: var(--shadow-soft);
  }

  .case-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .case-media picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .case-overview-section {
    padding: 0 0 3rem;
  }

  .case-facts {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1rem, 3vw, 1.6rem);
    padding: 1.25rem 0;
    border-block: 1px solid var(--color-border);
  }

  .case-facts span,
  .aside-block h2 {
    color: var(--color-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-facts p {
    margin: 0.45rem 0 0;
    color: var(--color-heading);
    font-weight: 700;
    line-height: 1.5;
  }

  .inline-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .inline-list li {
    color: var(--color-heading);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .inline-list li:not(:last-child)::after {
    content: '·';
    margin-left: 0.4rem;
    color: var(--color-muted);
  }

  .case-content-section {
    padding: 0 0 5rem;
  }

  .case-layout {
    display: grid;
    grid-template-columns: minmax(220px, 300px) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .case-aside {
    display: grid;
    gap: 1.4rem;
    position: sticky;
    top: 6rem;
  }

  .aside-block {
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .aside-block h2 {
    margin: 0 0 0.75rem;
  }

  .aside-block ul,
  .case-section ul {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-muted);
    line-height: 1.65;
  }

  .case-article {
    display: grid;
    gap: 0;
  }

  .case-section {
    padding: 0 0 2.2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .case-section + .case-section {
    padding-top: 2.2rem;
  }

  .case-section h2 {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(1.55rem, 3vw, 2.2rem);
    line-height: 1.12;
    letter-spacing: 0;
  }

  .case-section p,
  .case-section li {
    color: var(--color-muted);
    line-height: 1.75;
  }

  .case-section p {
    margin: 1rem 0 0;
  }

  .case-section ul {
    margin-top: 1rem;
  }

  .case-section--split {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.5rem, 4vw, 2.5rem);
  }

  @media (max-width: 900px) {
    .case-hero-grid,
    .case-layout,
    .case-section--split {
      grid-template-columns: 1fr;
    }

    .case-facts {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .case-aside {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .case-facts {
      grid-template-columns: 1fr;
    }
  }
</style>
