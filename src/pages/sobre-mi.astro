---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { profile } from '../data/profile';
import { education, featuredExperience } from '../data/experience';
---

<BaseLayout
  title={`Sobre mí | ${profile.displayName}`}
  description={`Perfil profesional de ${profile.formalName}, desarrollador trainee e Ingeniero Civil Industrial.`}
>
  <div class="page-shell">
    <Header />

    <main>
      <section class="page-hero">
        <div class="container page-hero-grid">
          <div>
            <p class="eyebrow">Sobre mí</p>
            <h1>{profile.formalName}</h1>
          </div>

          <p>
            Soy Ingeniero Civil Industrial y actualmente estoy orientando mi perfil al
            desarrollo web, con foco en Python, Django, SQL y construcción de aplicaciones
            claras, mantenibles y pensadas para el uso real.
          </p>
        </div>
      </section>

      <section class="content-section">
        <div class="container content-grid">
          <aside class="section-side">
            <p class="eyebrow">Perfil</p>
            <h2>Una base de ingeniería aplicada al desarrollo web.</h2>
          </aside>

          <div class="rich-text">
            <p>
              Me interesa construir soluciones web que no solo funcionen, sino que también
              sean ordenadas, comprensibles y fáciles de mantener. Mi formación en ingeniería
              me ha dado una mirada analítica sobre procesos, datos y mejora continua, mientras
              que mi formación reciente en desarrollo me ha permitido trabajar con aplicaciones
              web, backend, bases de datos y control de versiones.
            </p>

            <p>
              Actualmente busco integrarme a un equipo en roles trainee o junior, donde pueda
              seguir creciendo técnicamente, aportar orden y aprender desde proyectos reales.
            </p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container content-grid">
          <aside class="section-side">
            <p class="eyebrow">Experiencia</p>
            <h2>Experiencias relevantes para mi perfil tech.</h2>
          </aside>

          <div class="timeline">
            {featuredExperience.map((item) => (
              <article class="timeline-item">
                <p class="period">{item.period}</p>
                <h3>{item.role}</h3>
                <p class="organization">{item.organization}</p>
                <p>{item.summary}</p>

                <ul>
                  {item.highlights.map((highlight) => <li>{highlight}</li>)}
                </ul>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container content-grid">
          <aside class="section-side">
            <p class="eyebrow">Formación</p>
            <h2>Formación académica y técnica.</h2>
          </aside>

          <div class="education-list">
            {education.map((item) => (
              <article class="education-item">
                <p>{item.period}</p>
                <h3>{item.title}</h3>
                <span>{item.institution}</span>
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .page-hero {
    padding: 5rem 0 4rem;
  }

  .page-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: end;
  }

  .page-hero h1 {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(3rem, 7vw, 5.2rem);
    line-height: 0.98;
    letter-spacing: -0.08em;
  }

  .page-hero p:not(.eyebrow) {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.12rem;
    line-height: 1.78;
  }

  .content-section {
    padding: 4rem 0;
    border-top: 1px solid var(--color-border);
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(220px, 0.42fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
  }

  .section-side h2 {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(1.6rem, 3vw, 2.35rem);
    line-height: 1.12;
    letter-spacing: -0.055em;
  }

  .rich-text p {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .rich-text p + p {
    margin-top: 1.2rem;
  }

  .timeline,
  .education-list {
    display: grid;
    gap: 1rem;
  }

  .timeline-item,
  .education-item {
    padding: 1.35rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.04);
  }

  .period,
  .education-item p {
    margin: 0 0 0.55rem;
    color: var(--color-primary-deep);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .timeline-item h3,
  .education-item h3 {
    margin: 0;
    color: var(--color-heading);
    font-size: 1.25rem;
    letter-spacing: -0.035em;
  }

  .organization,
  .education-item span {
    display: block;
    margin-top: 0.25rem;
    color: var(--color-muted);
    font-weight: 680;
  }

  .timeline-item p:not(.period):not(.organization) {
    color: var(--color-muted);
    line-height: 1.72;
  }

  .timeline-item ul {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
    color: var(--color-muted);
    line-height: 1.75;
  }

  @media (max-width: 820px) {
    .page-hero-grid,
    .content-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
